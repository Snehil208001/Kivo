# Shopify Storefront API credentials
# Get these from: Shopify Admin > Settings > Apps and sales channels > Develop apps
# Create an app, enable Storefront API, and copy the Storefront API access token.

VITE_SHOPIFY_DOMAIN=your-store.myshopify.com
VITE_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token

# Storefront API version (optional, defaults to a recent stable version)
VITE_SHOPIFY_API_VERSION=2026-07

# WhatsApp support number in international format, digits only (optional)
VITE_WHATSAPP_NUMBER=919999999999
